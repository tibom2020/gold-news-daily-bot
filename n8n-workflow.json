{
  "name": "Gold News Daily Bot",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        },
        "timezone": "Asia/Ho_Chi_Minh"
      },
      "id": "schedule-trigger",
      "name": "Schedule 08:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://gold-news-daily-bot.onrender.com/health",
        "options": { "timeout": 60000 }
      },
      "id": "wake-up",
      "name": "Wake Render",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300],
      "onError": "continue",
      "notes": "Gọi /health để đánh thức Render (cold start)"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://gold-news-daily-bot.onrender.com/webhook",
        "options": { "timeout": 90000 }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 30000,
      "id": "http-request",
      "name": "Gọi Gold News Bot",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [650, 300],
      "notes": "Deploy: https://gold-news-daily-bot.onrender.com"
    }
  ],
  "connections": {
    "Schedule 08:00": {
      "main": [[{ "node": "Wake Render", "type": "main", "index": 0 }]]
    },
    "Wake Render": {
      "main": [[{ "node": "Gọi Gold News Bot", "type": "main", "index": 0 }]]
    }
  },
  "settings": {},
  "staticData": null,
  "meta": {
    "templateCredsSetupCompleted": false
  }
}
