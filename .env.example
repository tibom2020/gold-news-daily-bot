# Gemini API - Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Telegram Bot - Tạo qua @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Optional: n8n webhook (bỏ trống nếu không dùng)
N8N_WEBHOOK_URL=

# Optional: Bảo vệ /webhook - n8n gửi header X-Webhook-Secret: your_secret
WEBHOOK_SECRET=
